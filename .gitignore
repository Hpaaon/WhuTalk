# Python 编译缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# 数据库文件（本地开发数据不提交）
*.db
*.sqlite
*.sqlite3

# 日志文件
*.log

# 本地配置文件（敏感信息）
.env
.venv
config.local.py

